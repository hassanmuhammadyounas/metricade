{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vector-metadata",
  "title": "Vector Metadata",
  "description": "Exact metadata stored per vector in Upstash Vector index",
  "type": "object",
  "properties": {
    "trace_id": { "type": "string" },
    "client_id": { "type": "string" },
    "session_id": { "type": "string" },
    "received_at": { "type": "number" },
    "ip_country": { "type": "string" },
    "ip_type": { "type": "string" },
    "device_type": { "type": "string" },
    "cluster_label": {
      "type": "string",
      "enum": ["FRAUD_BOT", "HIGH_INTENT", "MEDIUM_INTENT", "LOW_INTENT", "UNASSIGNED"],
      "description": "Assigned by clustering job — absent until first clustering run"
    },
    "cluster_id": {
      "type": "integer",
      "description": "HDBSCAN cluster id — -1 means noise"
    }
  }
}
