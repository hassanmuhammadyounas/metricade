{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stream-message",
  "title": "Stream Message",
  "description": "Exact fields in every Redis Stream entry in behavioral_stream",
  "type": "object",
  "required": ["trace_id", "received_at", "ip_meta", "ua_meta", "time_features", "payload"],
  "properties": {
    "trace_id": { "type": "string" },
    "received_at": { "type": "number", "description": "Unix timestamp ms" },
    "ip_meta": {
      "type": "object",
      "properties": {
        "ip": { "type": "string" },
        "ip_type": { "type": "string", "enum": ["residential", "datacenter", "vpn", "tor", "unknown"] },
        "ip_country": { "type": "string" },
        "ip_asn": { "type": "string" }
      }
    },
    "ua_meta": {
      "type": "object",
      "properties": {
        "browser_family": { "type": "string" },
        "os_family": { "type": "string" },
        "device_type": { "type": "string", "enum": ["desktop", "mobile", "tablet", "bot", "unknown"] },
        "is_webview": { "type": "boolean" },
        "webview_type": { "type": ["string", "null"] }
      }
    },
    "time_features": {
      "type": "object",
      "properties": {
        "hour_sin": { "type": "number" },
        "hour_cos": { "type": "number" },
        "dow_sin": { "type": "number" },
        "dow_cos": { "type": "number" }
      }
    },
    "payload": { "$ref": "event-payload" }
  }
}
