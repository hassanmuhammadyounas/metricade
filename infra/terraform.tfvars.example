# Cloudflare
cf_account_id    = "REPLACE_ME"
cf_api_token     = "REPLACE_ME"          # Needs: Workers:Edit, Workers Routes:Edit
cf_zone_id       = "REPLACE_ME"          # Only if using custom domain

# Fly.io
fly_api_token    = "REPLACE_ME"
fly_app_name     = "behavioral-inference"
fly_region       = "iad"                 # Match Upstash region — minimise Redis RTT

# Upstash
upstash_email    = "REPLACE_ME"
upstash_api_key  = "REPLACE_ME"
upstash_region   = "us-east-1"           # Must match fly_region
vector_dims      = 192                   # Transformer output dimension — DO NOT CHANGE after first upsert
vector_similarity = "COSINE"            # SimCLR-trained vectors work best with cosine
