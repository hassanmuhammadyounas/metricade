# ── Cloudflare ──────────────────────────────────────────────
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_ZONE_ID=
INGEST_SHARED_SECRET=           # Shared between Worker internal routes and monitoring scripts

# ── Fly.io ──────────────────────────────────────────────────
FLY_API_TOKEN=
FLY_APP_NAME=behavioral-inference
FLY_REGION=iad

# ── Upstash Redis ────────────────────────────────────────────
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ── Upstash Vector ───────────────────────────────────────────
UPSTASH_VECTOR_URL=
UPSTASH_VECTOR_TOKEN=
VECTOR_DIMS=192
VECTOR_SIMILARITY=COSINE

# ── Stream / Queue Config ────────────────────────────────────
STREAM_NAME=behavioral_stream
CONSUMER_GROUP=inference_group
DLQ_KEY=behavioral_dlq
HEARTBEAT_KEY=fly_worker_heartbeat
HEARTBEAT_TIMEOUT_S=60

# ── Model ────────────────────────────────────────────────────
MODEL_PATH=/models/v1_simclr_trained.pt
BOOTSTRAP_MODEL_PATH=/models/bootstrap_random.pt
