{
  "title": "Pipeline Health",
  "description": "End-to-end pipeline health: events/min, DLQ depth, inference lag",
  "panels": [
    {
      "id": 1,
      "title": "Events Ingested / min",
      "type": "timeseries",
      "metric": "cloudflare_worker_requests_per_minute",
      "filter": { "route": "/ingest", "status": 200 }
    },
    {
      "id": 2,
      "title": "DLQ Depth",
      "type": "stat",
      "metric": "behavioral_dlq_count",
      "thresholds": [
        { "value": 0, "color": "green" },
        { "value": 1, "color": "yellow" },
        { "value": 100, "color": "red" }
      ]
    },
    {
      "id": 3,
      "title": "Stream Pending Messages",
      "type": "timeseries",
      "metric": "behavioral_stream_pending_count"
    },
    {
      "id": 4,
      "title": "Inference Latency (ms)",
      "type": "timeseries",
      "metric": "inference_worker_last_inference_ms"
    },
    {
      "id": 5,
      "title": "Heartbeat Age (s)",
      "type": "stat",
      "metric": "fly_worker_heartbeat_age_seconds",
      "thresholds": [
        { "value": 0, "color": "green" },
        { "value": 45, "color": "yellow" },
        { "value": 60, "color": "red" }
      ]
    }
  ]
}
